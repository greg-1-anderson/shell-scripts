#!/usr/bin/env bash
# gh-api-safe — read-only wrapper for 'gh api'.
#
# Only forwards requests that are provably read-only:
#   1. The endpoint must match the built-in allow-list.
#   2. No flags that introduce a request body or change the HTTP method
#      away from GET/HEAD.
#
# Exits 77 (EX_NOPERM from sysexits) when a request is blocked.
#
# Because -f/--field is blocked (it switches the default method to POST),
# pass query parameters directly in the URL:
#   gh-api-safe 'repos/owner/repo/issues?state=open&per_page=100'

set -euo pipefail

readonly EX_NOPERM=77
readonly SELF="${0##*/}"

die_blocked() {
    printf '%s: not allowed — %s\n' "$SELF" "$1" >&2
    exit "$EX_NOPERM"
}

if [[ $# -eq 0 ]]; then
    cat >&2 <<EOF
Usage: $SELF <endpoint> [gh-api flags...]

Read-only wrapper for 'gh api'. Forwards the request only when the
endpoint is in the allow-list and no write-enabling flags are present.

Exits $EX_NOPERM (EX_NOPERM) when a request is blocked.
Exits with gh's own code on API errors.

Pass query parameters in the URL, not via -f (which is blocked):
  $SELF 'repos/owner/repo/issues?state=open&per_page=100'

Safe flags (passed through):
  --paginate       --jq -q          --template -t
  --cache          --header -H      --include -i
  --silent         --slurp          --verbose
  --hostname       --preview -p
EOF
    exit 2
fi

# ---------------------------------------------------------------------------
# Phase 1: scan arguments — extract API path, detect method, block writes
# ---------------------------------------------------------------------------

api_path=""
method=""
i=1

while [[ $i -le $# ]]; do
    arg="${!i}"
    case "$arg" in
        # ---- Write-enabling flags: block immediately ----
        #   -f / --raw-field   (adds string params, changes default to POST)
        #   -F / --field       (adds typed params, changes default to POST)
        #   --input            (provides request body)
        -[fF])
            die_blocked "flag $arg sets request body fields (changes default method to POST)" ;;
        -[fF]?*)
            die_blocked "flag ${arg:0:2} sets request body fields (changes default method to POST)" ;;
        --field|--field=*)
            die_blocked "--field/-F sets request body fields (changes default method to POST)" ;;
        --raw-field|--raw-field=*)
            die_blocked "--raw-field/-f sets request body fields (changes default method to POST)" ;;
        --input|--input=*)
            die_blocked "--input provides a request body" ;;

        # ---- Method flag: capture for validation ----
        -X)
            ((i++))
            [[ $i -le $# ]] || die_blocked "-X requires a value"
            method="${!i}" ;;
        -X?*)
            method="${arg:2}" ;;
        --method)
            ((i++))
            [[ $i -le $# ]] || die_blocked "--method requires a value"
            method="${!i}" ;;
        --method=*)
            method="${arg#--method=}" ;;

        # ---- Safe flags that consume the next argument ----
        #   -q/--jq  -t/--template  -H/--header  -p/--preview
        #   --cache  --hostname
        --cache|--hostname|--jq|--preview|-[qtHp])
            ((i++)) ;;

        # ---- Other flags (booleans, --key=val forms): skip ----
        -*) ;;

        # ---- Positional: first one is the API endpoint ----
        *)
            [[ -z "$api_path" ]] && api_path="$arg" ;;
    esac
    ((i++))
done

# ---------------------------------------------------------------------------
# Phase 2: validate HTTP method
# ---------------------------------------------------------------------------

if [[ -n "$method" ]]; then
    method_upper="$(printf '%s' "$method" | tr '[:lower:]' '[:upper:]')"
    case "$method_upper" in
        GET|HEAD) ;;
        *) die_blocked "method '$method' is not read-only (only GET and HEAD are allowed)" ;;
    esac
fi

# ---------------------------------------------------------------------------
# Phase 3: normalize API path
# ---------------------------------------------------------------------------

[[ -n "$api_path" ]] || die_blocked "no API endpoint provided"

path="$api_path"
path="${path#https://api.github.com/}"   # strip full-URL prefix
path="${path#/}"                          # strip leading slash
path="${path%%\?*}"                       # strip query string
path="${path%/}"                          # strip trailing slash

