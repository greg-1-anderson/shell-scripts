#!/usr/bin/env bash
set -euo pipefail

CLAUDE_DIR="$HOME/.claude"
SETTINGS_FILE="$CLAUDE_DIR/settings.json"

# Safe permissions list — everything here gets added to permissions.allow
SAFE_PERMISSIONS=(
  'Read'
  'Read(/Users/greg/Code/pantheon/**)'
  'WebSearch'
  'WebFetch(*)'
  'LS'
  'Grep'
  'Glob'
  'Bash(cd *)'
  'Bash(ls *)'
  'Bash(cat *)'
