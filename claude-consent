  'Bash(npx tsc --noEmit*)'
  'Bash(go vet*)'
  'Bash(go test*)'
  'Bash(pytest*)'
  'Bash(python -m pytest*)'
  'Bash(python3 -m pytest*)'
  'Bash(plantuml*)'
  'Bash(man *)'
  'Bash(composer show*)'
  'Bash(composer install*)'
  'Bash(kubectl get *)'
  'Bash(kubectl describe *)'
  'Bash(kubectl logs *)'
  'Bash(docker ps*)'
  'Bash(docker images*)'
  'Bash(docker inspect*)'
  'Bash(docker logs*)'
  'Bash(brew list*)'
  'Bash(brew info*)'
