  'Bash(git stash list*)'
  'Bash(gh pr view*)'
  'Bash(gh pr diff*)'
  'Bash(gh search*)'
  'Bash(gh auth status)'
  'Bash(gh-api-safe*)'
  'Bash(go build*)'
  'Bash(npm test*)'
  'Bash(npm run test*)'
