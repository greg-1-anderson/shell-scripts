if [[ ! -f "$SETTINGS_FILE" ]]; then
  echo "Error: $SETTINGS_FILE not found" >&2
  exit 1
fi

if ! command -v jq &>/dev/null; then
  echo "Error: jq is required but not installed" >&2
  exit 1
fi

# Ensure ~/.claude is a git repo
if ! git -C "$CLAUDE_DIR" rev-parse --git-dir &>/dev/null; then
  echo "Initializing git repo in $CLAUDE_DIR..."
  git -C "$CLAUDE_DIR" init
  git -C "$CLAUDE_DIR" add -A
  git -C "$CLAUDE_DIR" commit -m "Initial commit"
fi

# Build JSON array of safe permissions
safe_json=$(printf '%s\n' "${SAFE_PERMISSIONS[@]}" | jq -R . | jq -s .)

# Merge safe permissions into settings.json:
# - Add any missing items to permissions.allow (preserving existing ones)
# - Set defaultMode to acceptEdits
jq --argjson safe "$safe_json" '
  .permissions.allow = ((.permissions.allow // []) + $safe | unique) |
  .permissions.defaultMode = "acceptEdits"
' "$SETTINGS_FILE" > "$SETTINGS_FILE.tmp" && mv "$SETTINGS_FILE.tmp" "$SETTINGS_FILE"

# Update CLAUDE.md with managed content
managed_block="${CONSENT_MARKER_START}
${CLAUDE_MD_CONTENT}
${CONSENT_MARKER_END}"

if [[ ! -f "$CLAUDE_MD" ]]; then
  printf '%s\n' "$managed_block" > "$CLAUDE_MD"
elif grep -qF "$CONSENT_MARKER_START" "$CLAUDE_MD"; then
  # Replace existing managed block
  awk -v start="$CONSENT_MARKER_START" -v end="$CONSENT_MARKER_END" -v block="$managed_block" '
    $0 == start { print block; skip=1; next }
    skip && $0 == end { skip=0; next }
    !skip { print }
  ' "$CLAUDE_MD" > "$CLAUDE_MD.tmp" && mv "$CLAUDE_MD.tmp" "$CLAUDE_MD"
else
  # Append managed block
  printf '\n%s\n' "$managed_block" >> "$CLAUDE_MD"
fi

# Show what changed
echo ""
changed_files=()
git -C "$CLAUDE_DIR" diff --quiet -- settings.json || changed_files+=(settings.json)
git -C "$CLAUDE_DIR" diff --quiet -- CLAUDE.md 2>/dev/null || changed_files+=(CLAUDE.md)

if [[ ${#changed_files[@]} -eq 0 ]]; then
  echo "No changes needed — everything is already up to date."
  exit 0
fi

git -C "$CLAUDE_DIR" diff -- "${changed_files[@]}"
echo ""

read -rp "Accept these changes? [y/N] " answer
if [[ "$answer" =~ ^[Yy]$ ]]; then
  git -C "$CLAUDE_DIR" add "${changed_files[@]}"
  git -C "$CLAUDE_DIR" commit -m "Apply claude-consent settings"
  echo "Changes committed."
else
  git -C "$CLAUDE_DIR" checkout -- "${changed_files[@]}"
  echo "Changes reverted."
fi
